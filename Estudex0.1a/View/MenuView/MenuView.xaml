<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.MenuView"
             BackgroundColor="#1a1a2e">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <!-- Header Card -->
            <Frame BackgroundColor="#2d2b55" CornerRadius="20" Padding="16" BorderColor="#3d3b6e">
                <VerticalStackLayout Spacing="0">

                    <!-- Avatar + Nome + Badge -->
                    <HorizontalStackLayout Spacing="12" Margin="0,0,0,10">
                        <Frame BackgroundColor="#7c3aed" CornerRadius="26"
                               WidthRequest="52" HeightRequest="52"
                               Padding="0" BorderColor="#c084fc" HasShadow="False">
                            <Label Text="👤" FontSize="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                            <Label x:Name="LabelNome" Text=""
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#e0e0ff"/>
                            <Frame BackgroundColor="#7c3aed33" CornerRadius="10"
                                   Padding="6,2" BorderColor="#c084fc44" HasShadow="False">
                                <Label x:Name="LabelPerfil" Text=""
                                       FontSize="11" TextColor="#c084fc"/>
                            </Frame>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Bio + botão editar -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12" x:Name="GridBio">
                        <Label x:Name="LabelBio"
                               Grid.Column="0"
                               Text=""
                               FontSize="12" TextColor="#a09abf"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="✏️"
                               FontSize="14"
                               VerticalOptions="Center"
                               Margin="8,0,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditarBioClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#3d3b6e" Margin="0,0,0,12"/>

                    <!-- Stats -->
                    <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,14" x:Name="GridStats">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="LabelAtividades" Text="0"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#c084fc" HorizontalOptions="Center"/>
                            <Label Text="Atividades" FontSize="10"
                                   TextColor="#7c6aaa" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="LabelAcertos" Text="0%"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#c084fc" HorizontalOptions="Center"/>
                            <Label Text="Acertos" FontSize="10"
                                   TextColor="#7c6aaa" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="LabelConquistas" Text="0"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#c084fc" HorizontalOptions="Center"/>
                            <Label Text="Conquistas" FontSize="10"
                                   TextColor="#7c6aaa" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Divider -->
                    <BoxView x:Name="DividerSelos" HeightRequest="1" Color="#3d3b6e" Margin="0,0,0,10"/>

                    <!-- Selos -->
                    <VerticalStackLayout x:Name="LayoutSelos" Spacing="8">
                        <Label Text="SELOS" FontSize="10" TextColor="#7c6aaa" CharacterSpacing="1"/>
                        <HorizontalStackLayout Spacing="8">
                            <Frame BackgroundColor="#7c3aed22" CornerRadius="10"
                                   WidthRequest="36" HeightRequest="36"
                                   Padding="0" BorderColor="#c084fc44" HasShadow="False">
                                <Label Text="⭐" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Frame BackgroundColor="#7c3aed22" CornerRadius="10"
                                   WidthRequest="36" HeightRequest="36"
                                   Padding="0" BorderColor="#c084fc44" HasShadow="False">
                                <Label Text="🏆" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Frame BackgroundColor="#7c3aed22" CornerRadius="10"
                                   WidthRequest="36" HeightRequest="36"
                                   Padding="0" BorderColor="#c084fc44" HasShadow="False">
                                <Label Text="🎯" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Frame BackgroundColor="#1a1a2e" CornerRadius="10"
                                   WidthRequest="36" HeightRequest="36"
                                   Padding="0" BorderColor="#3d3b6e" HasShadow="False"
                                   Opacity="0.4">
                                <Label Text="🔒" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Frame BackgroundColor="#1a1a2e" CornerRadius="10"
                                   WidthRequest="36" HeightRequest="36"
                                   Padding="0" BorderColor="#3d3b6e" HasShadow="False"
                                   Opacity="0.4">
                                <Label Text="🔒" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Menu Professor -->
            <VerticalStackLayout x:Name="MenuProfessor" Spacing="8">
                <Label Text="MENU" FontSize="10" TextColor="#7c6aaa"
                       CharacterSpacing="1" Margin="2,4,0,0"/>
                <Frame BackgroundColor="#2d2b55" CornerRadius="14" Padding="14,12" BorderColor="#3d3b6e">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#7c3aed22" CornerRadius="10"
                               WidthRequest="34" HeightRequest="34" Padding="0" BorderColor="#c084fc44" HasShadow="False">
                            <Label Text="📋" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Atividades" FontSize="14" FontAttributes="Bold" TextColor="#e0e0ff"/>
                            <Label Text="Gerenciar atividades" FontSize="11" TextColor="#7c6aaa"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#4d3b8e" VerticalOptions="Center"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAtividadesClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>
                <Frame BackgroundColor="#2d2b55" CornerRadius="14" Padding="14,12" BorderColor="#3d3b6e">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#185FA522" CornerRadius="10"
                               WidthRequest="34" HeightRequest="34" Padding="0" BorderColor="#85B7EB44" HasShadow="False">
                            <Label Text="❓" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Dúvidas" FontSize="14" FontAttributes="Bold" TextColor="#e0e0ff"/>
                            <Label Text="Ver dúvidas dos alunos" FontSize="11" TextColor="#7c6aaa"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#4d3b8e" VerticalOptions="Center"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDuvidasClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </VerticalStackLayout>

            <!-- Menu Aluno -->
            <VerticalStackLayout x:Name="MenuAluno" Spacing="8">
                <Label Text="ESTUDOS" FontSize="10" TextColor="#7c6aaa"
                       CharacterSpacing="1" Margin="2,4,0,0"/>
                <Frame BackgroundColor="#2d2b55" CornerRadius="14" Padding="14,12" BorderColor="#3d3b6e">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#7c3aed22" CornerRadius="10"
                               WidthRequest="34" HeightRequest="34" Padding="0" BorderColor="#c084fc44" HasShadow="False">
                            <Label Text="📋" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Atividades" FontSize="14" FontAttributes="Bold" TextColor="#e0e0ff"/>
                            <Label Text="Ver e responder atividades" FontSize="11" TextColor="#7c6aaa"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#4d3b8e" VerticalOptions="Center"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAtividadesAlunoClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>
                <Frame BackgroundColor="#2d2b55" CornerRadius="14" Padding="14,12" BorderColor="#3d3b6e">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="#185FA522" CornerRadius="10"
                               WidthRequest="34" HeightRequest="34" Padding="0" BorderColor="#85B7EB44" HasShadow="False">
                            <Label Text="❓" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Minhas Dúvidas" FontSize="14" FontAttributes="Bold" TextColor="#e0e0ff"/>
                            <Label Text="Suas perguntas enviadas" FontSize="11" TextColor="#7c6aaa"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#4d3b8e" VerticalOptions="Center"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDuvidasAlunoClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </VerticalStackLayout>

            <!-- Logout -->
            <Button Text="🚪 Sair da conta"
                    BackgroundColor="#7c3aed"
                    TextColor="White"
                    HorizontalOptions="Fill"
                    CornerRadius="14"
                    Margin="0,4,0,0"
                    Clicked="OnLogoutClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
