<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ListagemDuvidaAlunoView"
             Title="Minhas Dúvidas"
             BackgroundColor="#0d0d14">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header -->
            <HorizontalStackLayout Spacing="12">
                <Frame BackgroundColor="#7c3aed" CornerRadius="20" Padding="0"
                       WidthRequest="40" HeightRequest="40" HasShadow="False">
                    <Label Text="?" FontSize="18" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
                <Label Text="Minhas Dúvidas" FontSize="28" FontAttributes="Bold"
                       TextColor="#c084fc" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#2a2a3d" />

            <!-- Cards -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Frame Grid.Column="0" BackgroundColor="#1a1a2e" CornerRadius="16"
                       Padding="16" BorderColor="#2a2a3d">
                    <HorizontalStackLayout Spacing="12">
                        <Frame BackgroundColor="#2d2b55" CornerRadius="24" Padding="0"
                               WidthRequest="48" HeightRequest="48" HasShadow="False">
                            <Label Text="📖" FontSize="20" HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Série" FontSize="12" TextColor="#a0a0c0" />
                            <Label Text="{Binding Serie}" FontSize="18"
                                   FontAttributes="Bold" TextColor="#c084fc" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#1a1a2e" CornerRadius="16"
                       Padding="16" BorderColor="#2a2a3d">
                    <HorizontalStackLayout Spacing="12">
                        <Frame BackgroundColor="#3a1a1a" CornerRadius="24" Padding="0"
                               WidthRequest="48" HeightRequest="48" HasShadow="False">
                            <Label Text="❓" FontSize="20" HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Minhas Dúvidas" FontSize="12" TextColor="#a0a0c0" />
                            <Label Text="{Binding Total}" FontSize="18"
                                   FontAttributes="Bold" TextColor="#c084fc" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>
            </Grid>

            <!-- Botão nova dúvida -->
            <Button Text="+ Nova Dúvida"
                    BackgroundColor="#7c3aed"
                    TextColor="White"
                    CornerRadius="24"
                    FontAttributes="Bold"
                    FontSize="15"
                    HeightRequest="48"
                    WidthRequest="180"
                    HorizontalOptions="End"
                    Clicked="OnNovaDuvidaClicked" />

            <!-- Busca + filtros -->
            <Grid ColumnDefinitions="2*,1.2*,1.2*" ColumnSpacing="12">
                <Frame Grid.Column="0" BackgroundColor="#1a1a2e" CornerRadius="14"
                       Padding="0" BorderColor="#2a2a3d" HeightRequest="48">
                    <HorizontalStackLayout Spacing="8" Margin="14,0" VerticalOptions="Center">
                        <Label Text="🔍" FontSize="14" VerticalOptions="Center" />
                        <Entry Text="{Binding TextoBusca}"
                               Placeholder="Buscar minhas dúvidas..."
                               PlaceholderColor="#7070a0"
                               TextColor="#e0e0ff"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#1a1a2e" CornerRadius="14"
                       Padding="0" BorderColor="#2a2a3d" HeightRequest="48">
                    <Picker ItemsSource="{Binding ListaDisciplinas}"
                            SelectedItem="{Binding DisciplinaSelecionada}"
                            TextColor="#e0e0ff"
                            BackgroundColor="Transparent"
                            Margin="14,0"
                            VerticalOptions="Center" />
                </Frame>

                <Frame Grid.Column="2" BackgroundColor="#1a1a2e" CornerRadius="14"
                       Padding="0" BorderColor="#2a2a3d" HeightRequest="48">
                    <Picker ItemsSource="{Binding ListaStatus}"
                            SelectedItem="{Binding StatusSelecionado}"
                            TextColor="#e0e0ff"
                            BackgroundColor="Transparent"
                            Margin="14,0"
                            VerticalOptions="Center" />
                </Frame>
            </Grid>

            <!-- Loading -->
            <ActivityIndicator IsVisible="{Binding IsLoading}"
                                IsRunning="{Binding IsLoading}"
                                Color="#7c3aed"
                                HeightRequest="40" />

            <!-- Erro -->
            <Frame IsVisible="{Binding MostrarErro}"
                   BackgroundColor="#1a1a2e" CornerRadius="16"
                   Padding="32" BorderColor="#2a2a3d">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="⚠" FontSize="36" HorizontalOptions="Center" TextColor="#7070a0" />
                    <Label Text="Erro ao carregar dúvidas" FontSize="15"
                           TextColor="#a0a0c0" HorizontalOptions="Center" />
                    <Button Text="Tentar novamente"
                            BackgroundColor="#2d2b55"
                            TextColor="#c084fc"
                            CornerRadius="10"
                            Padding="16,8"
                            Command="{Binding RecarregarCommand}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Vazio -->
            <Frame IsVisible="{Binding MostrarVazio}"
                   BackgroundColor="#1a1a2e" CornerRadius="16"
                   Padding="32" BorderColor="#2a2a3d">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="✦" FontSize="36" HorizontalOptions="Center" TextColor="#c084fc" />
                    <Label Text="Nenhuma dúvida encontrada" FontSize="15"
                           TextColor="#a0a0c0" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Lista -->
            <CollectionView ItemsSource="{Binding Duvidas}"
                             SelectionMode="Single"
                             SelectionChanged="OnDuvidaSelecionada">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1a1a2e" CornerRadius="14"
                               Padding="16" BorderColor="#2a2a3d" Margin="0,0,0,12">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Titulo}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#c084fc" />
                                    <Frame Grid.Column="1" CornerRadius="8"
                                           Padding="8,4" BorderColor="Transparent"
                                           BackgroundColor="#3a2a0a">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame"
                                                         Binding="{Binding StatusDuvida}"
                                                         Value="Respondida">
                                                <Setter Property="BackgroundColor" Value="#1a3a1a" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Label Text="{Binding StatusDuvida}" FontSize="12"
                                               TextColor="#f59e0b">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding StatusDuvida}"
                                                             Value="Respondida">
                                                    <Setter Property="TextColor" Value="#4ade80" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Frame>
                                </Grid>
                                <Label Grid.Row="1"
                                       Text="{Binding Disciplina.Nome}"
                                       FontSize="12" TextColor="#a0a0c0" />
                                <Label Grid.Row="2"
                                       Text="{Binding Descricao}"
                                       FontSize="13" TextColor="#a0a0c0"
                                       LineBreakMode="TailTruncation" MaxLines="2" />
                                <Label Grid.Row="3"
                                       Text="{Binding Momento, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                       FontSize="12" TextColor="#a0a0c0"
                                       HorizontalOptions="End" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
