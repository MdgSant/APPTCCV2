<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.Utilizador.CadastroView"
             Title="Cadastro"
             BackgroundColor="#1a1a2e">

    <ScrollView>
        <VerticalStackLayout Padding="32,40" Spacing="0">

            <!-- Mascote + Nome -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,32">
                <Image Source="ornitorrinco.png"
                       WidthRequest="130"
                       HeightRequest="130"
                       HorizontalOptions="Center"/>
                <Label Text="BEM VINDO(A) AO"
                       FontSize="13"
                       TextColor="#a0a0c0"
                       HorizontalTextAlignment="Center"/>
                <Label Text="ESTUDEX!"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#c084fc"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Título -->
            <VerticalStackLayout Spacing="4" Margin="0,0,0,24">
                <Label Text="Criar Conta"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#c084fc"/>
                <Label Text="Preencha os dados abaixo para se registrar"
                       FontSize="12"
                       TextColor="#a0a0c0"/>
            </VerticalStackLayout>

            <!-- Nome -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="NOME COMPLETO" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="Seu nome completo"
                           Text="{Binding Nome}"
                           PlaceholderColor="#6a6a8a"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- CPF -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="CPF" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="000.000.000-00"
                           Text="{Binding Cpf}"
                           PlaceholderColor="#6a6a8a"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           Keyboard="Numeric"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Cidade -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="CIDADE" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="Sua cidade"
                           Text="{Binding Cidade}"
                           PlaceholderColor="#6a6a8a"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- UF -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="ESTADO (UF)" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="SP"
                           Text="{Binding Uf}"
                           PlaceholderColor="#6a6a8a"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           MaxLength="2"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Email -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="E-MAIL" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="seu@email.com"
                           Text="{Binding Email}"
                           PlaceholderColor="#6a6a8a"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           Keyboard="Email"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Senha -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,14">
                <Label Text="SENHA" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Grid ColumnDefinitions="*,48">
                        <Entry Grid.Column="0"
                               Placeholder="••••••••"
                               Text="{Binding Senha}"
                               IsPassword="True"
                               PlaceholderColor="#6a6a8a"
                               TextColor="#e0e0ff"
                               BackgroundColor="Transparent"
                               Margin="16,12,0,12"/>
                        <Button Grid.Column="1"
                                Text="👁"
                                Command="{Binding AlternarMostrarSenhaCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#a0a0c0"
                                Padding="0"/>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

            <!-- Tipo de Usuário -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,20">
                <Label Text="TIPO DE USUÁRIO" TextColor="#a0a0c0" FontSize="10"/>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Picker Title="Selecione o perfil"
                            SelectedItem="{Binding TipoSelecionado}"
                            TextColor="#e0e0ff"
                            BackgroundColor="Transparent"
                            Margin="16,12">
                        <Picker.Items>
                            <x:String>Aluno</x:String>
                            <x:String>Professor</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>
            </VerticalStackLayout>

            <!-- Termos -->
            <HorizontalStackLayout Spacing="8" Margin="0,0,0,24">
                <CheckBox IsChecked="{Binding AceitarTermos}" Color="#c084fc"/>
                <Label VerticalOptions="Center" FontSize="12">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Aceito os " TextColor="#a0a0c0"/>
                            <Span Text="termos de serviço" TextColor="#c084fc" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <!-- Botão Registrar -->
            <Button Text="REGISTRAR →"
                    Command="{Binding RegistrarCommand}"
                    BackgroundColor="#c084fc"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="52"
                    FontSize="15"
                    FontAttributes="Bold"
                    Margin="0,0,0,20"
                    HorizontalOptions="Fill"/>

            <!-- Link Login -->
            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="Já tem conta?" TextColor="#a0a0c0" FontSize="12"/>
                <Label Text="Entrar" TextColor="#c084fc" FontSize="12"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
