<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.Utilizador.LoginView"
             Title="LoginView"
             BackgroundColor="#1a1a2e">

    <!-- Layout responsivo: Grid para desktop, StackLayout para mobile -->
    <Grid x:Name="MainGrid" RowDefinitions="*" ColumnDefinitions="*,*" Padding="0">

            <!-- Ornitorrinco Image -->
            <Image Source="ornitorrinco.png"
                   x:Name="OrnitImage"
                   WidthRequest="250"
                   HeightRequest="250"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <!-- Bem-vindo Text -->
            <StackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Bem-vindo de volta ao"
                       FontSize="20"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"/>

                <Label Text="EstudeX"
                       FontSize="32"
                       TextColor="#c77dff"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"/>
            </StackLayout>

        <!-- LADO DIREITO - Formulário -->
        <ScrollView Grid.Column="1" 
                    x:Name="RightPanel"
                    BackgroundColor="#1a1a2e">
            <VerticalStackLayout Padding="50,60" Spacing="25">

                <!-- Header -->
                <StackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🔐" FontSize="24"/>
                        <Label Text="Entrar"
                               FontSize="32"
                               TextColor="White"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Text="Acesse sua conta e continue estudando"
                           FontSize="14"
                           TextColor="#b0b0b0"
                           Margin="0,0,0,10"/>
                </StackLayout>

                <!-- Email Field -->
                <StackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✉️" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="E-MAIL"
                               FontSize="12"
                               TextColor="#999"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Frame para estilizar o Entry -->
                    <Frame BorderColor="#444"
                           CornerRadius="8"
                           Padding="0"
                           HasShadow="False"
                           BackgroundColor="#2a2a3e">
                        <Entry Placeholder="seu@email.com"
                               Text="{Binding Email}"
                               PlaceholderColor="#666"
                               TextColor="White"
                               FontSize="14"
                               Margin="16"/>
                    </Frame>
                </StackLayout>

                <!-- Senha Field -->
                <StackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔒" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="SENHA"
                               FontSize="12"
                               TextColor="#999"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Frame para estilizar o Entry -->
                    <Frame BorderColor="#444"
                           CornerRadius="8"
                           Padding="0"
                           HasShadow="False"
                           BackgroundColor="#2a2a3e">
                        <Entry Placeholder="••••••••"
                               Text="{Binding Senha}"
                               IsPassword="True"
                               PlaceholderColor="#666"
                               TextColor="White"
                               FontSize="14"
                               Margin="16"/>
                    </Frame>
                </StackLayout>

                <!-- Lembrar-me e Esqueceu Senha -->
                <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                    <CheckBox IsChecked="{Binding LembrarMe}" 
                             Color="#c77dff"/>
                    <Label Text="Lembrar-me"
                           FontSize="12"
                           TextColor="#b0b0b0"
                           VerticalOptions="Center"/>
                    <Label Text="Esqueceu a senha?"
                           FontSize="12"
                           TextColor="#c77dff"
                           FontAttributes="Bold"
                           HorizontalOptions="EndAndExpand"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EsqueceuSenhaCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Botão Entrar -->
                <Button Text="ENTRAR →"
                        Command="{Binding AutenticarCommand}"
                        BackgroundColor="#c77dff"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        Padding="20,16"
                        CornerRadius="8"
                        Margin="0,20,0,0"
                        HorizontalOptions="Fill"/>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding Carregando}"
                                  IsVisible="{Binding Carregando}"
                                  Color="#c77dff"
                                  Margin="0,10"/>

                <!-- Divisor -->
                <HorizontalStackLayout Spacing="10" Margin="0,20">
                    <BoxView Color="#444" HeightRequest="1" HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                    <Label Text="ou" TextColor="#666" FontSize="12" VerticalOptions="Center"/>
                    <BoxView Color="#444" HeightRequest="1" HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Cadastro Link -->
                <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="Não possui login?"
                           FontSize="13"
                           TextColor="#b0b0b0"/>
                    <Label Text="Cadastre-se"
                           FontSize="13"
                           TextColor="#c77dff"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DirecionarCadastroCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
