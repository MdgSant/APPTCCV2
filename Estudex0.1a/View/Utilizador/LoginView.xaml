<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.Utilizador.LoginView"
             Title="LoginView"
             BackgroundColor="#1a1a2e">

    <ScrollView>
        <VerticalStackLayout Padding="32,40" Spacing="0">

            <!-- Mascote + Nome -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,32">
                <Image Source="ornitorrinco.png"
                       WidthRequest="160"
                       HeightRequest="160"
                       HorizontalOptions="Center"/>
                <Label Text="Bem-vindo de volta ao"
                       FontSize="15"
                       TextColor="#b0b0b0"
                       HorizontalTextAlignment="Center"/>
                <Label Text="EstudeX"
                       FontSize="28"
                       TextColor="#c77dff"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"/>
            </VerticalStackLayout>

            <!-- Header -->
            <VerticalStackLayout Spacing="4" Margin="0,0,0,24">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="🔐" FontSize="22"/>
                    <Label Text="Entrar"
                           FontSize="26"
                           TextColor="White"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Acesse sua conta e continue estudando"
                       FontSize="13"
                       TextColor="#b0b0b0"/>
            </VerticalStackLayout>

            <!-- Email -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,16">
                <HorizontalStackLayout Spacing="6">
                    <Label Text="✉️" FontSize="13" VerticalOptions="Center"/>
                    <Label Text="E-MAIL" FontSize="11" TextColor="#999"
                           FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="seu@email.com"
                           Text="{Binding Email}"
                           PlaceholderColor="#666"
                           TextColor="White"
                           FontSize="14"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Senha -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,16">
                <HorizontalStackLayout Spacing="6">
                    <Label Text="🔒" FontSize="13" VerticalOptions="Center"/>
                    <Label Text="SENHA" FontSize="11" TextColor="#999"
                           FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Frame BorderColor="#444" CornerRadius="10" Padding="0"
                       HasShadow="False" BackgroundColor="#2a2a3e">
                    <Entry Placeholder="••••••••"
                           Text="{Binding Senha}"
                           IsPassword="True"
                           PlaceholderColor="#666"
                           TextColor="White"
                           FontSize="14"
                           Margin="16,12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Lembrar-me -->
            <HorizontalStackLayout Spacing="8" Margin="0,0,0,24">
                <CheckBox IsChecked="{Binding LembrarMe}" Color="#c77dff"/>
                <Label Text="Lembrar-me" FontSize="12" TextColor="#b0b0b0"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Botão Entrar -->
            <Button Text="ENTRAR →"
                    Command="{Binding AutenticarCommand}"
                    BackgroundColor="#c77dff"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="52"
                    CornerRadius="10"
                    Margin="0,0,0,16"
                    HorizontalOptions="Fill"/>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding Carregando}"
                               IsVisible="{Binding Carregando}"
                               Color="#c77dff"
                               Margin="0,8"/>

            <!-- Divisor -->
            <HorizontalStackLayout Spacing="10" Margin="0,16">
                <BoxView Color="#444" HeightRequest="1"
                         HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                <Label Text="ou" TextColor="#666" FontSize="12" VerticalOptions="Center"/>
                <BoxView Color="#444" HeightRequest="1"
                         HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Cadastro Link -->
            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="Não possui login?" FontSize="13" TextColor="#b0b0b0"/>
                <Label Text="Cadastre-se" FontSize="13" TextColor="#c77dff"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DirecionarCadastroCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
