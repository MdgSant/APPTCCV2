<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.DuvidaView"
             Title="Dúvidas"
             BackgroundColor="#0d0d14">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header -->
            <HorizontalStackLayout Spacing="12">
                <Frame BackgroundColor="#7c3aed" CornerRadius="20" Padding="0"
                       WidthRequest="40" HeightRequest="40" HasShadow="False">
                    <Label Text="?" FontSize="18" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
                <Label Text="Dúvidas dos Alunos" FontSize="28" FontAttributes="Bold"
                       TextColor="#c084fc" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#2a2a3d" />

            <!-- Cards de métricas -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Frame Grid.Column="0" BackgroundColor="#1a1a2e" CornerRadius="16"
                       Padding="14" BorderColor="#2a2a3d">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="🕐" FontSize="20" HorizontalOptions="Center" />
                        <Label Text="Pendentes" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                        <Label Text="{Binding TotalPendentes}" FontSize="22" FontAttributes="Bold"
                               TextColor="#f59e0b" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#1a1a2e" CornerRadius="16"
                       Padding="14" BorderColor="#2a2a3d">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="20" HorizontalOptions="Center" />
                        <Label Text="Respondidas" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                        <Label Text="{Binding TotalRespondidas}" FontSize="22" FontAttributes="Bold"
                               TextColor="#4ade80" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2" BackgroundColor="#1a1a2e" CornerRadius="16"
                       Padding="14" BorderColor="#2a2a3d">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="📋" FontSize="20" HorizontalOptions="Center" />
                        <Label Text="Total" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                        <Label Text="{Binding Total}" FontSize="22" FontAttributes="Bold"
                               TextColor="#c084fc" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Filtro por ID -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Frame Grid.Column="0" BackgroundColor="#1a1a2e" CornerRadius="14"
                       Padding="0" BorderColor="#2a2a3d" HeightRequest="48">
                    <Entry x:Name="EntryIdDuvida"
                           Placeholder="Buscar por ID da dúvida"
                           PlaceholderColor="#7070a0"
                           TextColor="#e0e0ff"
                           BackgroundColor="Transparent"
                           Keyboard="Numeric"
                           Margin="16,0"
                           VerticalOptions="Center" />
                </Frame>
                <Button Grid.Column="1" Text="🔍"
                        BackgroundColor="#7c3aed"
                        TextColor="White"
                        CornerRadius="14"
                        WidthRequest="48"
                        HeightRequest="48"
                        Clicked="OnBuscarPorIdClicked" />
            </Grid>

            <!-- Lista -->
            <CollectionView ItemsSource="{Binding Duvidas}"
                             SelectionMode="Single"
                             SelectionChanged="OnDuvidaSelecionada">
                <CollectionView.EmptyView>
                    <Frame BackgroundColor="#1a1a2e" CornerRadius="16"
                           Padding="28" BorderColor="#2a2a3d">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="✦" FontSize="32" HorizontalOptions="Center" TextColor="#c084fc" />
                            <Label Text="Nenhuma dúvida encontrada" FontSize="14"
                                   TextColor="#a0a0c0" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1a1a2e" CornerRadius="14"
                               Padding="16" BorderColor="#2a2a3d" Margin="0,0,0,12">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding Utilizador.Nome}"
                                           FontSize="15" FontAttributes="Bold" TextColor="#e0e0ff" />
                                    <Frame Grid.Column="1" CornerRadius="8" Padding="8,4"
                                           BorderColor="Transparent" BackgroundColor="#3a2a0a">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding StatusDuvida}" Value="Respondida">
                                                <Setter Property="BackgroundColor" Value="#1a3a1a" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Label Text="{Binding StatusDuvida}" FontSize="12" TextColor="#f59e0b">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusDuvida}" Value="Respondida">
                                                    <Setter Property="TextColor" Value="#4ade80" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Frame>
                                </Grid>
                                <Label Grid.Row="1" Text="{Binding Disciplina.Nome}" FontSize="12" TextColor="#a0a0c0" />
                                <Label Grid.Row="2" Text="{Binding Titulo}" FontSize="15" FontAttributes="Bold" TextColor="#c084fc" />
                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding Descricao}" FontSize="13" TextColor="#a0a0c0"
                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                    <Label Grid.Column="1" Text="{Binding Momento, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                           FontSize="12" TextColor="#7070a0" VerticalOptions="End" />
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
